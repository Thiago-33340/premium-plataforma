[
  {
    "id": "est-produto-create",
    "module": "estoque-v2",
    "method": "POST",
    "path": "/api/est/produto",
    "screen": "public/estoque.html / public/admin.html",
    "permission": "editar_produtos",
    "payload_required": ["usuario_id", "nome"],
    "payload_optional": ["categoria_id", "unidade", "estoque_minimo", "estoque_ideal", "fornecedor_preferido_id", "pode_contar", "pode_comprar", "pode_produzir", "observacoes", "subcategoria", "marca_preferida", "peso_g", "unidade_base", "conversao_origem", "conversao_confianca", "conversao_precisa_revisao", "tipo_item", "nome_nf", "local_fisico_id", "setores"],
    "writes": ["est_produto", "est_produto_setor"],
    "success": "201 { ok: true, id }",
    "known_errors": ["400 informe o nome", "403 Sem permissão", "400 Já existe um produto com esse nome."]
  },
  {
    "id": "est-produto-update",
    "module": "estoque-v2",
    "method": "PATCH",
    "path": "/api/est/produto/:id",
    "screen": "public/estoque.html / public/admin.html",
    "permission": "editar_produtos",
    "payload_required": ["usuario_id", "nome"],
    "payload_optional": ["categoria_id", "unidade", "estoque_minimo", "estoque_ideal", "fornecedor_preferido_id", "pode_contar", "pode_comprar", "pode_produzir", "observacoes", "subcategoria", "marca_preferida", "peso_g", "ativo", "unidade_base", "conversao_origem", "conversao_confianca", "conversao_precisa_revisao", "tipo_item", "local_fisico_id", "setores"],
    "writes": ["est_produto", "est_produto_setor"],
    "success": "200 { ok: true }",
    "known_errors": ["400 Informe o nome.", "404 Produto não encontrado.", "400 Já existe um produto com esse nome."]
  },
  {
    "id": "est-configuracoes-tenant",
    "module": "estoque-v2",
    "method": "GET",
    "path": "/api/est/configuracoes",
    "screen": "public/estoque.html",
    "permission": "leitura não sensível do tenant",
    "reads": ["tenants.config.estoque", "est_produto.tipo_item/departamento", "est_categoria.departamento"],
    "writes": [],
    "success": "200 { config: { titulo, departamentos[], tipos_item[] }, fonte }",
    "known_errors": ["500 erro inesperado"],
    "side_effects": [
      "remove hardcodes do front de estoque sem apagar classificações existentes",
      "faz merge entre config do tenant, defaults neutros e valores já usados no cadastro"
    ]
  },
  {
    "id": "admin-estoque-cardapio-inventory",
    "module": "admin-gestor/estoque-vendavel",
    "method": "GET/PUT/DELETE",
    "path": "/api/admin/estoque-cardapio",
    "screen": "public/admin.html / aba Estoque do cardápio",
    "permission": "gestor",
    "payload_required": ["admin_id para escritas e leituras protegidas"],
    "payload_optional": ["status", "controle_enabled", "quantidade_vendavel", "dd_external_id", "itens[] em massa"],
    "reads": ["produtos", "opcoes", "opcao_grupos", "menu_categorias", "ficha_itens", "est_produto", "est_produto_setor", "tenants.config"],
    "writes": ["produtos.status/meta", "opcoes.status/meta", "tenants.config.estoque"],
    "success": "GET 200 { itens[], kpis, status_map, mapper }; PUT/DELETE 200 { ok: true }",
    "known_errors": ["403 acesso restrito ao gestor", "400 status inválido", "404 item do cardápio não encontrado"],
    "side_effects": [
      "não cria tabela nova",
      "quantidade vendável fica em produtos/opcoes.meta.inventory e não altera est_produto.estoque_atual",
      "status Titan ATIVO/EM_FALTA/OCULTO é mapeado para DD ACTIVE/SHORT_SUPPLY/HIDDEN",
      "mapper Delivery Direto fica preparado em meta.mapper.delivery_direto, sem sync ativo",
      "operação física continua em public/estoque.html e rotas /api/est/*"
    ]
  },
  {
    "id": "est-compra-manual",
    "module": "estoque-v2",
    "method": "POST",
    "path": "/api/est/compra",
    "screen": "public/estoque.html",
    "permission": "registrar_compra",
    "payload_required": ["usuario_id", "itens[]", "itens[].produto_id", "itens[].quantidade"],
    "payload_optional": ["fornecedor_id", "data_compra", "origem", "itens[].marca", "itens[].unidade", "itens[].valor_unitario", "itens[].valor_total", "itens[].texto_original", "itens[].match_score", "itens[].match_status"],
    "writes": ["est_compra", "est_compra_item", "est_produto", "est_movimento", "est_produto.legado.match_aliases"],
    "success": "201 { ok: true, id, total }",
    "known_errors": ["403 Sem permissão para registrar compra.", "400 Selecione ao menos um produto.", "400 quantidade maior que zero", "400 Produto da compra não encontrado ou inativo."],
    "transactional": true,
    "note": "Resolve usuario_id por UUID/login/apelido e grava entrada de estoque, movimento e custos em uma transação."
  },
  {
    "id": "est-produto-match",
    "module": "estoque-v2/compras",
    "method": "POST",
    "path": "/api/est/match-produtos",
    "screen": "public/estoque.html / entrada de compra, perdas/consumo, automacao Khardela",
    "permission": "gestor ou registrar_compra/acessar_lancamentos/acessar_produtos",
    "payload_required": ["usuario_id", "textos[] ou texto"],
    "payload_optional": ["textos[].idx", "textos[].marca", "textos[].unidade"],
    "reads": ["est_produto", "est_categoria", "est_produto.legado.match_aliases"],
    "writes": [],
    "success": "200 { resultados: [{ idx, texto, melhor, sugestoes[], status }] }",
    "known_errors": ["403 Sem permissao para consultar vinculos de produtos."],
    "side_effects": [
      "nao cria produto automaticamente",
      "status auto exige score alto e diferenca minima para o segundo colocado",
      "status sugestao exige confirmacao/manual do gestor antes de lancar compra"
    ]
  },
  {
    "id": "est-movimento-foto",
    "module": "estoque-v2/perdas-consumo",
    "method": "POST",
    "path": "/api/est/movimento/foto",
    "screen": "public/estoque.html / Perda/consumo",
    "permission": "gestor ou acessar_lancamentos",
    "payload_required": ["usuario_id", "image"],
    "payload_optional": ["tipo"],
    "reads": ["imagem enviada pelo gestor", "est_produto", "est_categoria"],
    "writes": [],
    "success": "200 { produto, quantidade, unidade, leitura_balanca, observacao, confianca, match }",
    "known_errors": ["400 leitura por imagem nao configurada", "403 Sem permissao", "502 leitura da foto falhou"],
    "side_effects": [
      "nao baixa estoque automaticamente",
      "preenche a tela para revisao do gestor",
      "usa /api/est/match-produtos para sugerir produto existente"
    ]
  },
  {
    "id": "est-produto-ficha-simple",
    "module": "estoque-v2/producao-fichas",
    "method": "PUT",
    "path": "/api/est/produto/:id/ficha",
    "screen": "public/estoque.html",
    "permission": "editar_produtos",
    "payload_required": ["usuario_id", "rendimento", "itens[]"],
    "payload_optional": ["itens[].observacao"],
    "writes": ["est_producao_receita", "est_ficha_producao", "est_ficha_porcao", "est_ficha_porcao_item", "est_produto"],
    "success": "200 { ok: true, itens, rendimento }",
    "known_errors": ["409 produto tem várias porções; editar na aba Produção", "400 ingrediente repetido", "400 quantidade inválida"],
    "note": "Editor simples grava uma porção e recusa produtos que já possuem múltiplas porções."
  },
  {
    "id": "producao-ficha-save",
    "module": "producao-fichas",
    "method": "PUT",
    "path": "/api/est/producao/ficha",
    "screen": "public/estoque.html / public/admin.html",
    "permission": "editar_produtos",
    "payload_required": ["usuario_id", "produto_id", "porcoes[]"],
    "payload_optional": ["descricao", "unidade_consumo", "tipo", "instrucoes", "setores", "porcoes[].itens[].observacao"],
    "writes": ["est_ficha_producao", "est_ficha_porcao", "est_ficha_porcao_item", "est_producao_receita", "est_produto", "est_produto_setor"],
    "success": "200 { ok: true, ficha_id, porcoes }",
    "known_errors": ["400 Produto inválido.", "400 A ficha precisa ter pelo menos uma porção.", "400 porção sem rendimento", "400 ingrediente repetido/inválido"]
  },
  {
    "id": "producao-run",
    "module": "producao-fichas",
    "method": "POST",
    "path": "/api/est/producao/run",
    "screen": "public/estoque.html",
    "permission": "acessar_producao_interna",
    "payload_required": ["usuario_id", "produto_id"],
    "payload_optional": ["quantidade", "porcao_id", "lotes", "rendido", "observacao"],
    "writes": ["est_producao_run", "est_produto", "est_movimento"],
    "success": "200 { ok: true, avisos, insumos_baixados, produzido_depois, rendido, perda, perda_pct, alerta_perda }",
    "known_errors": ["403 Faça login.", "403 Sem permissão", "400 porção não encontrada", "400 ficha sem ingredientes", "404 produto produzido não encontrado"],
    "transactional": true,
    "note": "Baixa insumos com FOR UPDATE, insere movimentos de PRODUCAO_BAIXA e PRODUCAO_ENTRADA, registra perda se rendido menor que base."
  },
  {
    "id": "contagem-iniciar",
    "module": "contagem-auditoria",
    "method": "POST",
    "path": "/api/est/contagem/iniciar",
    "screen": "public/estoque.html",
    "permission": "fazer_contagem",
    "payload_required": ["usuario_id", "setor_id"],
    "reads": ["rbac_contacts", "est_setor", "est_produto_setor", "est_produto", "tenants.config"],
    "writes": ["est_contagem", "est_contagem_item"],
    "success": "201 { contagem, itens, geral } ou 200 { contagem, itens, retomada: true }",
    "known_errors": ["400 informe usuario_id e setor_id", "403 Sem permissão", "403 setor não atribuído", "400 setor sem itens"]
  },
  {
    "id": "contagem-item-save",
    "module": "contagem-auditoria",
    "method": "PATCH",
    "path": "/api/est/contagem/:id/item/:itemId",
    "screen": "public/estoque.html",
    "permission": "fazer_contagem ou gestor",
    "payload_required": ["usuario_id"],
    "payload_optional": ["quantidade", "status", "observacao"],
    "writes": ["est_contagem_item"],
    "success": "200 { ok: true, item }",
    "known_errors": ["403 contagem de outro colaborador", "409 contagem encerrada", "400 quantidade inválida"]
  },
  {
    "id": "contagem-encerrar",
    "module": "contagem-auditoria",
    "method": "POST",
    "path": "/api/est/contagem/:id/encerrar",
    "screen": "public/estoque.html",
    "permission": "fazer_contagem ou gestor",
    "payload_required": ["usuario_id"],
    "payload_optional": ["itens[]", "observacoes"],
    "writes": ["est_contagem", "est_contagem_item", "est_notificacao"],
    "success": "200 { ok: true, itens_contados }",
    "known_errors": ["403 contagem de outro colaborador", "409 contagem encerrada", "400 obrigatórios pendentes"]
  },
  {
    "id": "contagem-auditar",
    "module": "contagem-auditoria",
    "method": "POST",
    "path": "/api/est/contagem/:id/auditar",
    "screen": "public/estoque.html",
    "permission": "auditar_contagem",
    "payload_required": ["usuario_id", "acao"],
    "payload_optional": ["observacao"],
    "writes": ["est_contagem", "est_auditoria", "est_produto", "est_movimento"],
    "success": "200 { ok: true }",
    "known_errors": ["403 Sem permissão", "400 ação inválida", "409 Só é possível aprovar contagem encerrada"],
    "side_effects": ["acao=aprovar atualiza estoque_atual de cada item contado e grava movimento CONTAGEM", "acao=corrigir volta status para EM_ANDAMENTO"]
  },
  {
    "id": "estoque-usuario-setores",
    "module": "permissoes-staff",
    "method": "PATCH",
    "path": "/api/est/usuario/:id",
    "screen": "public/estoque.html / Mais / Permissões da equipe",
    "permission": "editar_permissoes",
    "payload_required": ["usuario_id"],
    "payload_optional": ["setores_permitidos", "apelido_login", "ativo"],
    "writes": ["rbac_contacts"],
    "success": "200 { ok: true, setores_permitidos }",
    "known_errors": ["403 Apenas gestor ou gerente", "404 Usuário alvo não encontrado"],
    "side_effects": ["altera remotamente quais setores o colaborador pode contar sem precisar do PIN dele"]
  },
  {
    "id": "estoque-usuario-pin",
    "module": "permissoes-staff",
    "method": "POST",
    "path": "/api/est/usuario/:id/pin",
    "screen": "public/estoque.html / Mais / Permissões da equipe",
    "permission": "editar_permissoes",
    "payload_required": ["usuario_id", "pin"],
    "payload_optional": ["pin_must_change"],
    "writes": ["rbac_contacts.pin_hash", "rbac_contacts.pin_changed_at", "rbac_contacts.pin_must_change"],
    "success": "200 { ok: true, pin_must_change }",
    "known_errors": ["403 Apenas gestor ou gerente", "400 PIN precisa ter 4 a 6 dígitos", "404 Usuário alvo não encontrado"],
    "side_effects": ["define PIN temporário com hash pgcrypto; por padrão obriga o usuário a trocar no primeiro acesso"]
  },
  {
    "id": "command-ai-console",
    "module": "command-center",
    "method": "POST",
    "path": "/api/mapper/ai",
    "screen": "public/mapper.html / command-center / aba Agentes",
    "permission": "editar_project_state",
    "payload_required": ["prompt"],
    "payload_optional": ["provider", "assignment_id"],
    "reads": ["project-state/agent-bridge.json", "project-state/agent-workflow.json", "ambiente seguro: TITAN_ANTHROPIC_API_KEY ou TITAN_OPENAI_API_KEY"],
    "writes": ["project-state/command-audit-log.json", "titan_command_actions"],
    "success": "200 { ok: true, provider, model, resposta, audit, persisted_db }",
    "known_errors": ["401 Faça login no Titan Tools.", "403 Sem permissão para esta ferramenta.", "400 prompt vazio ou contendo possível segredo.", "409 IA do Command não configurada.", "502 Falha/timeout ao chamar IA externa."],
    "side_effects": [
      "envia o prompt e contexto da missão ativa para provedor externo de IA configurado por variável de ambiente",
      "não expõe chave/modelo secreto na UI",
      "não grava prompt completo automaticamente; registra auditoria com provider, modelo, assignment_id e tamanhos",
      "resposta só vira relatório oficial quando o usuário clicar em Registrar relatório no Command"
    ]
  },
  {
    "id": "command-local-agent-poll",
    "module": "command-center",
    "method": "POST",
    "path": "/api/mapper/local-agent/poll",
    "screen": "scripts/titan-local-agent.mjs",
    "permission": "Bearer TITAN_LOCAL_AGENT_TOKEN",
    "payload_required": ["agent_id"],
    "payload_optional": ["host", "workspace"],
    "reads": ["project-state/local-agent-queue.json", "titan_command_actions"],
    "writes": [],
    "success": "200 { ok: true, agent_id, tasks[] }",
    "known_errors": ["401 Token do Titan Local Agent inválido ou ausente.", "409 Titan Local Agent não configurado no ambiente do serviço."],
    "side_effects": [
      "não executa nada no servidor",
      "retorna até 3 tarefas pendentes/aprovadas para o agent_id informado",
      "requer token configurado fora do Git/project-state"
    ]
  },
  {
    "id": "command-local-agent-report",
    "module": "command-center",
    "method": "POST",
    "path": "/api/mapper/local-agent/report",
    "screen": "scripts/titan-local-agent.mjs",
    "permission": "Bearer TITAN_LOCAL_AGENT_TOKEN",
    "payload_required": ["agent_id", "task_id", "status"],
    "payload_optional": ["message", "result"],
    "writes": ["project-state/local-agent-queue.json", "project-state/command-audit-log.json", "titan_command_actions"],
    "success": "200 { ok: true, target, audit, persisted_db }",
    "known_errors": ["400 status inválido", "401 token inválido", "404 tarefa local não encontrada"],
    "side_effects": [
      "atualiza status e logs da tarefa local",
      "registra auditoria como local-agent:<agent_id>",
      "não altera código, Git, deploy ou banco operacional"
    ]
  },
  {
    "id": "command-action",
    "module": "command-center",
    "method": "POST",
    "path": "/api/mapper/action",
    "screen": "public/mapper.html / command-center",
    "permission": "editar_project_state",
    "payload_required": ["action"],
    "payload_optional": ["titulo", "modulo", "prioridade", "categoria", "detalhe", "bloqueada", "id", "status", "proximo_passo", "severidade", "impacto", "mitigacao", "decisao", "motivo", "branch", "commit", "merge_commit", "servico", "ambiente", "dominios", "validacoes", "observacoes", "confirmacao", "agent", "assignment_id", "resumo", "achados", "recomendacoes", "testes_sugeridos", "bloqueios", "converte_em", "agent_id", "local_action", "prompt"],
    "writes": ["project-state/tasks.json", "project-state/risks.json", "project-state/decisions.json", "project-state/deploys.json", "project-state/agent-reports.json", "project-state/local-agent-queue.json", "project-state/command-audit-log.json", "titan_command_actions"],
    "success": "200/201 { ok: true, target, audit, persisted_db, db_action_id }",
    "known_errors": ["401 Faça login no Titan Tools.", "403 Sem permissão para esta ferramenta.", "400 Ação do Command não reconhecida.", "404 Tarefa não encontrada.", "409 Executor externo não configurado no ambiente."],
    "side_effects": [
      "create_task adiciona task-f2-XXX",
      "update_task altera status/próximo passo/bloqueio",
      "create_risk adiciona risk-XXX",
      "create_decision adiciona decision-XXX",
      "create_deploy_record adiciona registro governado em deploys.json sem acionar deploy automático",
      "approve_deploy_record atualiza deploys.json com aprovação/validação humana e exige confirmacao=AUTORIZO DEPLOY",
      "trigger_deploy_external aciona webhook configurado somente com permissão acionar_deploy, confirmação=ACIONAR DEPLOY e deploy previamente aprovado",
      "create_agent_report registra relatório do Claude/agente em agent-reports.json sem alterar código ou deploy",
      "create_local_agent_task cria tarefa aprovada para o Titan Local Agent sem executar comando livre",
      "toda ação gera command-audit-log.json",
      "toda ação tenta persistir em titan_command_actions; GET /api/mapper/state aplica overlay do banco sobre project-state"
    ]
  }
]
